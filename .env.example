# Copy to .env.local and fill in. .env.local is gitignored.

# --- Supabase ---
# From Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Site URL (used by the verification email + OG card) ---
NEXT_PUBLIC_SITE_URL=https://simedo.work

# --- Cloudflare R2 (trajectory storage, Phase 5) ---
# Create the bucket "helix-trajectories" (or whatever you set R2_BUCKET to),
# enable Public access, copy the public URL into R2_PUBLIC_URL, and create
# an API token with Object Read + Write for the bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=helix-trajectories
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# --- Resend (verification emails) ---
# https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=onboarding@resend.dev
